# ===================================
# AMBIENTE
# ===================================
NODE_ENV=production
PORT=3000

# ===================================
# BANCO DE DADOS
# ===================================
DATABASE_URL=postgresql://user:password@localhost:5432/cnpj_saas
DATABASE_POOL_SIZE=20

# ===================================
# CACHE (Redis)
# ===================================
REDIS_URL=redis://localhost:6379

# ===================================
# AUTENTICAÇÃO & SEGURANÇA
# ===================================
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui
JWT_EXPIRATION=7d
LICENSE_SECRET_KEY=sua_chave_secreta_para_licenças

# ===================================
# STRIPE (Pagamentos)
# ===================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Preços dos Planos (ID dos Products no Stripe)
STRIPE_PRICE_STARTER=price_starter_...
STRIPE_PRICE_PROFESSIONAL=price_prof_...
STRIPE_PRICE_ENTERPRISE=price_ent_...
STRIPE_PRICE_RESELLER=price_reseller_...

# ===================================
# API EXTERNA - CNPJ
# ===================================
CNPJ_API_URL=https://publica.cnpj.ws/cnpj
CNPJ_API_TIMEOUT=10000

# ===================================
# EMAIL
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
SMTP_FROM=noreply@cnpj-saas.com

# ===================================
# URLS E DOMINIOS
# ===================================
APP_URL=https://app.cnpj-saas.com
API_URL=https://api.cnpj-saas.com
FRONTEND_URL=https://cnpj-saas.com

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# LOGGING & MONITORAMENTO
# ===================================
LOG_LEVEL=info
SENTRY_DSN=https://sua_chave@sentry.io/seu_projeto

# ===================================
# UPLOAD DE ARQUIVOS
# ===================================
S3_BUCKET=cnpj-saas-files
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=sua_chave
S3_SECRET_ACCESS_KEY=sua_senha

# ===================================
# FEATURES
# ===================================
ENABLE_WHITE_LABEL=true
ENABLE_API_ACCESS=true
ENABLE_ADVANCED_REPORTS=true
ENABLE_ZAPIER_INTEGRATION=true

# ===================================
# SUPORTE
# ===================================
SUPPORT_EMAIL=suporte@cnpj-saas.com
SUPPORT_PHONE=+55 11 9999-9999
SUPPORT_CHAT_ENABLED=true
