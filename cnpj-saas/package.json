{
  "name": "cnpj-saas-backend",
  "version": "1.0.0",
  "description": "SaaS de Consulta CNPJ com White Label e Sistema de Licenciamento",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pkg": "pkg dist/index.js --targets node18-linux-x64 --output cnpj-saas-backend",
    "docker:build": "docker build -t cnpj-saas:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env cnpj-saas:latest"
  },
  "keywords": ["saas", "cnpj", "white-label", "licensing"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "ts-node": "^10.9.2",
    "pkg": "^5.11.5"
  }
}
